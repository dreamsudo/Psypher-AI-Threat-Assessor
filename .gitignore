# ─────────────────────────────────────────────────────────────
#  Psypher AI Threat Assessor — .gitignore
# ─────────────────────────────────────────────────────────────

# ── Python ──
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# ── Runtime output (per-run, regenerated) ──
assessments/
logs/
*.log

# ── Build artifacts & caches (regenerated by the pipeline / data builders) ──
build/

# ── Heavy data — rebuilt with:  data/fetch.sh  &&  data/nvd-build.sh  (+ the *_build.py scripts) ──
# NVD feeds + index  (multi-GB; single files can exceed GitHub's 100 MB hard limit)
data/nvd/
# All SQLite indexes (NVD + Debian)
*.sqlite
# Debian security-tracker dump (large; rebuilt via curl in distro_index.py)
data/distro/debian.json
# D3FEND raw exports (large; the compact slice below is kept instead)
data/d3fend/d3fend-full-mappings.json
data/d3fend/d3fend.json
# ATT&CK STIX bundles (~45 MB total; rebuilt via data/fetch.sh)
data/attack-stix-data/*.json
# CWE catalog XML (~10 MB; rebuilt via data/fetch.sh)
data/cwe/*.xml

# ── Kept on purpose (small; make the repo usable out of the box). Do NOT ignore: ──
#   data/cve/*.json                          seed CVEs
#   data/atlas-data/stix-atlas.json          ATLAS framework bundle
#   data/kev/kev.json                        exploited-CVE catalog
#   data/d3fend/cwe-countermeasures.json     defense slice the engine uses
#   packs/relevance/attack-artifact-map.json pack data
#   (all engine/, packs/, tests/, *.sh, *.py, *.yaml, schemas, docs, images/)

# ── Secrets / credentials — NEVER commit ──
.env
.env.*
*.pem
*.key
credentials.json

# ── OS / editor cruft ──
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/
